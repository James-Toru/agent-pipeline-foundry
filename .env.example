ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Gmail & Google Calendar & Google Sheets — obtain from Google Cloud Console
# Create OAuth2 credentials and generate a refresh token via OAuth Playground:
# https://developers.google.com/oauthplayground
# Required scopes: gmail.readonly, gmail.send, gmail.compose, calendar, spreadsheets, drive.file
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=

# Brave Search — obtain from https://brave.com/search/api/
BRAVE_API_KEY=

# HubSpot CRM — obtain a Private App access token from HubSpot settings
HUBSPOT_ACCESS_TOKEN=
HUBSPOT_PORTAL_ID=

# Slack — create a Slack App at https://api.slack.com/apps
# Bot Token Scopes: channels:read, channels:manage, chat:write, im:write, users:read
# Enable Interactivity and set the Request URL to: https://<your-domain>/api/integrations/slack/interactions
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=
SLACK_APPROVAL_CHANNEL=#agent-foundry-approvals

NOTION_API_KEY=
