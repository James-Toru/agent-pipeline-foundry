{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "rootDir": ".",
    "baseUrl": ".",
    "paths": {
      "@/lib/supabase-server": ["./src/lib/supabase-server"],
      "@/lib/docker-executor": ["./src/lib/docker-executor"],
      "@/*": ["../src/*"]
    },
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true
  },
  "include": ["src/**/*.ts", "../src/lib/**/*.ts", "../src/types/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
